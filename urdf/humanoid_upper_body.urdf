<?xml version="1.0"?>
<robot name="humanoid_upper_body" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ═══════════════════════════════════════════════════════════
       HUMANOID UPPER BODY — Fall Detection & Anti-Disturbance
       Joints: torso, neck, head, 2x shoulder, 2x elbow, 2x wrist
       Sensors: IMU (torso), IMU (head), force/torque (wrists)
       ═══════════════════════════════════════════════════════════ -->

  <!-- ── Materials ──────────────────────────────────────────── -->
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="light_grey">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <material name="blue_accent">
    <color rgba="0.1 0.4 0.9 1.0"/>
  </material>
  <material name="red_alert">
    <color rgba="0.9 0.1 0.1 1.0"/>
  </material>
  <material name="sensor_yellow">
    <color rgba="0.95 0.85 0.1 1.0"/>
  </material>

  <!-- ── BASE LINK (pelvis / mounting base) ─────────────────── -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.30 0.20 0.05"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.30 0.20 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0"
               iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <!-- ── TORSO ──────────────────────────────────────────────── -->
  <link name="torso">
    <visual>
      <origin xyz="0 0 0.20" rpy="0 0 0"/>
      <geometry>
        <box size="0.28 0.18 0.40"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.20" rpy="0 0 0"/>
      <geometry>
        <box size="0.28 0.18 0.40"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.20" rpy="0 0 0"/>
      <mass value="8.0"/>
      <inertia ixx="0.12" ixy="0.0" ixz="0.0"
               iyy="0.10" iyz="0.0" izz="0.05"/>
    </inertial>
  </link>

  <joint name="base_to_torso" type="fixed">
    <parent link="base_link"/>
    <child link="torso"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
  </joint>

  <!-- ── IMU SENSOR LINK (torso-mounted) ───────────────────── -->
  <link name="imu_torso_link">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.02"/>
      </geometry>
      <material name="sensor_yellow"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="torso_imu_joint" type="fixed">
    <parent link="torso"/>
    <child link="imu_torso_link"/>
    <origin xyz="0 0 0.38" rpy="0 0 0"/>
  </joint>

  <!-- ── NECK ───────────────────────────────────────────────── -->
  <link name="neck">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.10"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.10"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="torso_neck_joint" type="revolute">
    <parent link="torso"/>
    <child link="neck"/>
    <origin xyz="0 0 0.42" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="20" velocity="2.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ── HEAD ───────────────────────────────────────────────── -->
  <link name="head">
    <visual>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.10"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.10"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.006" ixy="0" ixz="0"
               iyy="0.006" iyz="0" izz="0.006"/>
    </inertial>
  </link>

  <joint name="neck_head_joint" type="revolute">
    <parent link="neck"/>
    <child link="head"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0.5" effort="10" velocity="1.5"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- ── IMU SENSOR LINK (head-mounted) ────────────────────── -->
  <link name="imu_head_link">
    <visual>
      <geometry>
        <box size="0.03 0.03 0.015"/>
      </geometry>
      <material name="sensor_yellow"/>
    </visual>
    <inertial>
      <mass value="0.03"/>
      <inertia ixx="0.00001" ixy="0" ixz="0"
               iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="head_imu_joint" type="fixed">
    <parent link="head"/>
    <child link="imu_head_link"/>
    <origin xyz="0 0 0.18" rpy="0 0 0"/>
  </joint>

  <!-- ════════════════════════════════════════
       LEFT ARM
       ════════════════════════════════════════ -->

  <!-- Left Shoulder -->
  <link name="left_shoulder">
    <visual>
      <geometry>
        <sphere radius="0.055"/>
      </geometry>
      <material name="blue_accent"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.055"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="left_shoulder_joint" type="revolute">
    <parent link="torso"/>
    <child link="left_shoulder"/>
    <origin xyz="0.17 0 0.35" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="50" velocity="2.0"/>
    <dynamics damping="1.0" friction="0.2"/>
  </joint>

  <!-- Left Upper Arm -->
  <link name="left_upper_arm">
    <visual>
      <origin xyz="0.13 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.26"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0.13 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.26"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.13 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.008" ixy="0" ixz="0"
               iyy="0.008" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="left_upper_arm_joint" type="revolute">
    <parent link="left_shoulder"/>
    <child link="left_upper_arm"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="40" velocity="2.0"/>
    <dynamics damping="0.8" friction="0.15"/>
  </joint>

  <!-- Left Elbow -->
  <link name="left_elbow">
    <visual>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
      <material name="blue_accent"/>
    </visual>
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.0005" ixy="0" ixz="0"
               iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="left_elbow_joint" type="revolute">
    <parent link="left_upper_arm"/>
    <child link="left_elbow"/>
    <origin xyz="0.26 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="2.618" effort="30" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- Left Forearm -->
  <link name="left_forearm">
    <visual>
      <origin xyz="0.11 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.028" length="0.22"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0.11 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.028" length="0.22"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.11 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.004" ixy="0" ixz="0"
               iyy="0.004" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="left_forearm_joint" type="revolute">
    <parent link="left_elbow"/>
    <child link="left_forearm"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="20" velocity="3.0"/>
    <dynamics damping="0.4" friction="0.08"/>
  </joint>

  <!-- Left Wrist -->
  <link name="left_wrist">
    <visual>
      <geometry>
        <sphere radius="0.030"/>
      </geometry>
      <material name="blue_accent"/>
    </visual>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0002" ixy="0" ixz="0"
               iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="left_wrist_joint" type="revolute">
    <parent link="left_forearm"/>
    <child link="left_wrist"/>
    <origin xyz="0.22 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="4.0"/>
    <dynamics damping="0.2" friction="0.05"/>
  </joint>

  <!-- ════════════════════════════════════════
       RIGHT ARM (mirror of left)
       ════════════════════════════════════════ -->

  <!-- Right Shoulder -->
  <link name="right_shoulder">
    <visual>
      <geometry>
        <sphere radius="0.055"/>
      </geometry>
      <material name="blue_accent"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.055"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="right_shoulder_joint" type="revolute">
    <parent link="torso"/>
    <child link="right_shoulder"/>
    <origin xyz="-0.17 0 0.35" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="50" velocity="2.0"/>
    <dynamics damping="1.0" friction="0.2"/>
  </joint>

  <!-- Right Upper Arm -->
  <link name="right_upper_arm">
    <visual>
      <origin xyz="-0.13 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.26"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="-0.13 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.26"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.13 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.008" ixy="0" ixz="0"
               iyy="0.008" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="right_upper_arm_joint" type="revolute">
    <parent link="right_shoulder"/>
    <child link="right_upper_arm"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="40" velocity="2.0"/>
    <dynamics damping="0.8" friction="0.15"/>
  </joint>

  <!-- Right Elbow -->
  <link name="right_elbow">
    <visual>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
      <material name="blue_accent"/>
    </visual>
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.0005" ixy="0" ixz="0"
               iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="right_elbow_joint" type="revolute">
    <parent link="right_upper_arm"/>
    <child link="right_elbow"/>
    <origin xyz="-0.26 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.618" upper="0.0" effort="30" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- Right Forearm -->
  <link name="right_forearm">
    <visual>
      <origin xyz="-0.11 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.028" length="0.22"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="-0.11 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.028" length="0.22"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.11 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.004" ixy="0" ixz="0"
               iyy="0.004" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="right_forearm_joint" type="revolute">
    <parent link="right_elbow"/>
    <child link="right_forearm"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="20" velocity="3.0"/>
    <dynamics damping="0.4" friction="0.08"/>
  </joint>

  <!-- Right Wrist -->
  <link name="right_wrist">
    <visual>
      <geometry>
        <sphere radius="0.030"/>
      </geometry>
      <material name="blue_accent"/>
    </visual>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0002" ixy="0" ixz="0"
               iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="right_wrist_joint" type="revolute">
    <parent link="right_forearm"/>
    <child link="right_wrist"/>
    <origin xyz="-0.22 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="4.0"/>
    <dynamics damping="0.2" friction="0.05"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════
       GAZEBO PLUGINS
       ═══════════════════════════════════════════════════ -->

  <!-- Gazebo ROS2 Control Plugin -->
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(find humanoid_balance_robot)/config/ros2_controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- IMU Plugin — Torso -->
  <gazebo reference="imu_torso_link">
    <sensor name="imu_torso" type="imu">
      <always_on>true</always_on>
      <update_rate>200</update_rate>
      <topic>/imu/torso</topic>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_torso_plugin">
        <ros>
          <remapping>~/out:=/imu/torso</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.002</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.002</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.002</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
    <material>Gazebo/Yellow</material>
  </gazebo>

  <!-- IMU Plugin — Head -->
  <gazebo reference="imu_head_link">
    <sensor name="imu_head" type="imu">
      <always_on>true</always_on>
      <update_rate>200</update_rate>
      <topic>/imu/head</topic>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_head_plugin">
        <ros>
          <remapping>~/out:=/imu/head</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
    <material>Gazebo/Yellow</material>
  </gazebo>

  <!-- Visual materials for Gazebo -->
  <gazebo reference="torso"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="base_link"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="neck"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="head"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="left_shoulder"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="left_upper_arm"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="left_elbow"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="left_forearm"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="left_wrist"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="right_shoulder"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="right_upper_arm"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="right_elbow"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="right_forearm"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="right_wrist"><material>Gazebo/Blue</material></gazebo>

</robot>
